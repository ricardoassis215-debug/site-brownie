# Public site origin — no trailing slash.
# Drives canonical URLs, Open Graph / Twitter tags, robots.txt, sitemap.xml,
# and JSON-LD structured data. Falls back to http://localhost:3000 when unset.
NEXT_PUBLIC_SITE_URL=https://example.com

# --- Server-only (no NEXT_PUBLIC_ prefix — never exposed to the browser) ---

# Optional upstream the /api/contact route forwards leads to (CRM / webhook).
# When unset, the route logs submissions server-side instead.
CONTACT_ENDPOINT=
